# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Whop OAuth
WHOP_CLIENT_ID=app_Lm1pKoAki3PWjp
WHOP_CLIENT_SECRET=apik_4iL6eHbgobdGQ_A2044867_C_a084c405052cd052b223d07e4eefb997276b8195d15cc207227084cf29ff1e
# IMPORTANT: You MUST register BOTH of these redirect URLs in your Whop dashboard:
# 1. https://ais-dev-g6dzapaevjjtdo3z2b7oi3-122467157455.europe-west3.run.app/api/auth/whop/callback
# 2. https://ais-pre-g6dzapaevjjtdo3z2b7oi3-122467157455.europe-west3.run.app/api/auth/whop/callback
