rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email == 'engmarwand@gmail.com' && 
             request.auth.token.email_verified == true; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validations ---
    function isValidUser(data) {
      return (data.plan == null || data.plan in ['starter', 'pro', 'agency', 'free']) &&
             (data.reportsGeneratedMonth == null || data.reportsGeneratedMonth is number);
    }

    function isValidWorkspace(data) {
      return (data.brand == null || data.brand is map) &&
             (data.color == null || data.color is map);
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if true; // Public for plan/tier verification
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming())) || isAdmin();
    }

    match /workspaces/{userId} {
      allow read: if true; // Public for branding
      allow create: if isOwner(userId) && isValidWorkspace(incoming());
      allow update: if (isOwner(userId) && isValidWorkspace(incoming())) || isAdmin();
    }

    match /user_config/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /workspaces_metadata/{workspaceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == workspaceId;
    }

    match /workspaceMembers/{memberId} {
      allow read: if isSignedIn() && (resource.data.workspaceId == request.auth.uid || resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid || resource.data.workspaceId != null);
      allow write: if isSignedIn();
    }

    match /workspaceFiles/{fileId} {
      allow read: if isSignedIn() && (resource.data.workspaceId == request.auth.uid || resource.data.uploadedBy == request.auth.uid || resource.data.workspaceId != null);
      allow write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.workspaceId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    match /campaigns/{campaignId} {
      allow get: if true;
      allow list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.workspaceId == request.auth.uid)) || (resource.data.portalEnabled == true);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    match /submissions/{submissionId} {
      allow get: if true;
      allow list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.workspaceId == request.auth.uid)) || (resource.data.campaignId != null);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    match /campaign_updates/{updateId} {
      allow get: if true;
      allow list: if isAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.workspaceId == request.auth.uid || resource.data.campaignId == 'All')) || (resource.data.clientVisible == true);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().authorId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().authorId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    match /campaign_briefs/{briefId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.workspaceId == request.auth.uid)) || (resource.data.campaignId != null);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    match /clipMetrics/{metricId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.workspaceId == request.auth.uid || resource.data.userId == null)) || (resource.data.campaignId != null);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && (existing().userId == request.auth.uid || existing().workspaceId == request.auth.uid));
    }

    // --- Workspace Subcollections ---
    match /workspaces/{workspaceId}/tasks/{taskId} {
      allow read, write: if isSignedIn();
    }
    match /workspaces/{workspaceId}/discussion/{messageId} {
      allow read, write: if isSignedIn();
    }
    match /workspaces/{workspaceId}/files/{fileId} {
      allow read, write: if isSignedIn();
    }
  }
}
