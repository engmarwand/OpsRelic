rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'engmarwand@gmail.com' && request.auth.token.email_verified == true;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      // Validate plan is valid
      let validPlan = (data.plan in ['starter', 'pro', 'agency'] && data.plan is string);
      let validCode = (data.passwordResetCode == null || (data.passwordResetCode is string && data.passwordResetCode.size() == 6));
      let validCreatedAt = (data.codeCreatedAt == null || data.codeCreatedAt is timestamp);
      
      return validPlan && validCode && validCreatedAt;
    }

    function isValidWorkspace(data) {
      // Allow partial updates but ensure types if present for safety
      // Ensuring it's a map and checking main sub-keys if present
      return (data.brand == null || (data.brand is map)) &&
             (data.color == null || (data.color is map)) &&
             (data.layout == null || (data.layout is map));
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.userId == request.auth.uid &&
             data.stage in ['Lead', 'Onboarding', 'Briefing', 'Active'];
    }

    function isValidCampaign(data) {
      return data.name is string && data.name.size() <= 200 &&
             (data.status == null || data.status in ['Draft', 'Review', 'Active', 'Complete', 'Intake Completed']) &&
             (data.intake == null || data.intake is map) &&
             (data.brief == null || data.brief is map);
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['userId', 'campaignId', 'title']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 500;
    }

    function isValidUpdate(data) {
      return data.campaignId is string &&
             data.content is string && data.content.size() <= 2000 &&
             data.authorId == request.auth.uid;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().keys().hasAll(['plan']);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    incoming().passwordResetCode is string && incoming().passwordResetCode.size() == 6 &&
                    incoming().codeCreatedAt is timestamp;
    }

    match /workspaces/{userId} {
      allow get: if true; // Public for branding
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && isValidWorkspace(incoming());
    }

    match /user_config/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /clients/{clientId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidClient(incoming());
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && isValidClient(incoming()) && 
                    incoming().userId == existing().userId) || isAdmin();
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    match /campaigns/{campaignId} {
      allow get: if true; 
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCampaign(incoming()) && incoming().userId == request.auth.uid;
      allow update: if (
        (isSignedIn() && existing().userId == request.auth.uid && isValidCampaign(incoming()) && incoming().userId == existing().userId)
        ||
        (
          isValidCampaign(incoming()) && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['intake', 'status', 'name', 'brief', 'updatedAt'])
        )
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow get: if true; // Allow public lookups for portal view
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || 
                    (resource.data.campaignId != null); // Allow public list for portals
      allow create: if isSignedIn() && isValidSubmission(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidSubmission(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /briefs/{briefId} {
      allow get: if isSignedIn() && resource.data.campaignId != null;
      allow list: if isSignedIn() && resource.data.campaignId != null;
      allow create: if isSignedIn() && incoming().campaignId != null;
      allow update: if isSignedIn() && existing().campaignId != null;
      allow delete: if isSignedIn() && existing().campaignId != null;
    }

    match /campaign_updates/{updateId} {
      allow list: if isAdmin() || (isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.campaignId == 'All')) ||
                    (resource.data.clientVisible == true); 
      allow create: if isSignedIn() && isValidUpdate(incoming());
      allow update: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid && isValidUpdate(incoming()));
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }
  }
}
