{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and subscription tier",
      "type": "object",
      "properties": {
        "plan": {
          "type": "string",
          "enum": ["starter", "pro", "agency"],
          "description": "Subscription tier of the user"
        }
      },
      "required": ["plan"]
    },
    "Workspace": {
      "title": "Workspace Settings",
      "description": "Agency branding and configuration",
      "type": "object",
      "properties": {
        "brand": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "tagline": { "type": "string" },
            "logoUrl": { "type": ["string", "null"] }
          }
        },
        "color": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" }
          }
        },
        "layout": {
          "type": "object",
          "properties": {
            "theme": { "type": "string" },
            "layout": { "type": "string" }
          }
        },
        "notifications": {
          "type": "object"
        }
      }
    },
    "ClientAccount": {
      "title": "ClientAccount",
      "description": "Represents a client or prospect in the CRM pipeline",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "stage": { "type": "string", "enum": ["Lead", "Qualified", "Proposal", "Won/Onboarding", "Active Client"] },
        "notes": { "type": "string" },
        "nextStep": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stage", "userId"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Tracking campaign for agency projects",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Review", "Active", "Complete"] },
        "intake": { "type": "object" },
        "brief": { 
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "objective": { "type": "string" },
            "angle": { "type": "string" },
            "nextSteps": { "type": "string" },
            "platforms": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "budget": { "type": "number" },
        "portalPassword": { "type": "string" },
        "portalToken": { "type": "string" },
        "portalEnabled": { "type": "boolean" },
        "revenue": { "type": "number" },
        "cpm": { "type": "number" },
        "maxPayout": { "type": "number" }
      },
      "required": ["name", "userId", "status"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Content asset submissions from creators",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "campaignId": { "type": "string" },
        "title": { "type": "string" },
        "views": { "type": "number" },
        "payout": { "type": "number" },
        "status": { "type": "string" },
        "platform": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["userId", "campaignId", "title"]
    },
    "UserConfig": {
      "title": "User Configuration",
      "description": "Creator pipeline, guidelines and message templates",
      "type": "object",
      "properties": {
        "invites": { "type": "array" },
        "guidelines": { "type": "array" },
        "templates": { "type": "array" }
      }
    },
    "ClipMetric": {
      "title": "Clip Metric",
      "description": "Live tracked views and engagement for a clip link",
      "type": "object",
      "properties": {
        "clipLinkId": { "type": "string" },
        "campaignId": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "platform": { "type": "string" },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "engagementRate": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clipLinkId", "campaignId", "userId", "url"]
    },
    "CampaignUpdate": {
      "title": "Campaign Update",
      "description": "Log entries and updates for campaign progress",
      "type": "object",
      "properties": {
        "campaignId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "clientVisible": { "type": "boolean" }
      }
    },
    "WorkspaceTask": {
      "title": "Workspace Task",
      "description": "Task for agency team collaboration",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "clientId": { "type": ["string", "null"] },
        "campaignId": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "dueDate": { "type": ["string", "null"], "format": "date" },
        "assigneeId": { "type": ["string", "null"] },
        "assigneeName": { "type": ["string", "null"] },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "title", "status", "creatorId"]
    },
    "WorkspaceMessage": {
      "title": "Workspace Message",
      "description": "Chat message or announcement in workspace",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mentions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["workspaceId", "authorId", "content", "timestamp"]
    },
    "WorkspaceFile": {
      "title": "Workspace File",
      "description": "Uploaded asset or link in the workspace",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "name", "url", "creatorId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user data"
    },
    "/workspaces/{userId}": {
      "schema": "Workspace",
      "description": "Agency workspace configuration"
    },
    "/workspaces/{workspaceId}/tasks/{taskId}": {
      "schema": "WorkspaceTask",
      "description": "Tasks within a workspace"
    },
    "/workspaces/{workspaceId}/discussion/{messageId}": {
      "schema": "WorkspaceMessage",
      "description": "Team discussion thread messages"
    },
    "/workspaces/{workspaceId}/files/{fileId}": {
      "schema": "WorkspaceFile",
      "description": "Recent assets and files"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Campaign documents"
    },
    "/clients/{clientId}": {
      "schema": "ClientAccount",
      "description": "Client and relationship documents"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Content submission documents"
    },
    "/campaign_briefs/{briefId}": {
      "schema": "Campaign",
      "description": "Detailed brief content for campaigns"
    },
    "/campaign_updates/{updateId}": {
      "schema": "CampaignUpdate",
      "description": "Activity logs for campaigns"
    },
    "/clipMetrics/{metricId}": {
      "schema": "ClipMetric",
      "description": "Performance metrics for tracked clips"
    },
    "/user_config/{userId}": {
      "schema": "UserConfig",
      "description": "Pipeline and CRM configuration for a user"
    }
  }
}
